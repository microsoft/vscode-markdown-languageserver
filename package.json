{
  "name": "vscode-markdown-languageserver",
  "description": "The language server that powers VS Code's Markdown support",
  "version": "0.5.0-alpha.14",
  "author": "Microsoft Corporation",
  "license": "MIT",
  "engines": {
    "node": "*"
  },
  "main": "./dist/node/workerMain.js",
  "browser": "./dist/browser/workerMain.js",
  "files": [
    "dist/**/*.js"
  ],
  "dependencies": {
    "@vscode/l10n": "^0.0.11",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-languageserver-types": "^3.17.5",
    "vscode-markdown-languageservice": "^0.5.0-alpha.12",
    "vscode-uri": "^3.0.7"
  },
  "overrides": {
    "serialize-javascript": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@typescript/native-preview": "^7.0.0-dev.20260423.1",
    "esbuild": "^0.28.0",
    "path-browserify": "^1.0.1"
  },
  "scripts": {
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "compile": "npm run typecheck && node esbuild.mjs",
    "watch": "tsgo -p tsconfig.json --noEmit --watch & node esbuild.mjs --watch",
    "prepublishOnly": "npm run typecheck && node esbuild.mjs"
  }
}